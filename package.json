{
  "name": "astro-resume",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "generate-pdf": "tsx ./scripts/generate-pdf.ts",
    "generate-pdf:ci": "start-server-and-test 3000 generate-pdf",
    "build": "astro check && tsc --noEmit && yarn generate-pdf:ci && astro build",
    "astro": "astro"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^3.1.1",
    "@fontsource/poppins": "^5.0.8",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "^20.5.0",
    "astro": "^2.9.6",
    "playwright": "^1.37.0",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.2.8",
    "start-server-and-test": "^2.0.0",
    "tailwindcss": "^3.3.3",
    "tsx": "^3.12.7"
  },
  "dependencies": {
    "astro-icon": "^0.8.0",
    "typescript": "5.1.6"
  }
}
