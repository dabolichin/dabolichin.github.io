{
  "name": "astro-resume",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "generate-pdf": "tsx ./scripts/generate-pdf.ts",
    "generate-pdf:ci": "start-server-and-test 3000 generate-pdf",
    "build": "astro check && tsc --noEmit && yarn generate-pdf:ci && astro build",
    "astro": "astro"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^3.0.1",
    "@fontsource/poppins": "^4.5.10",
    "@tailwindcss/typography": "^0.5.9",
    "@types/node": "^18.15.11",
    "astro": "^2.0.15",
    "playwright": "^1.32.2",
    "prettier": "^2.8.7",
    "prettier-plugin-tailwindcss": "^0.2.7",
    "start-server-and-test": "^2.0.0",
    "tailwindcss": "^3.3.1",
    "tsx": "^3.12.6"
  },
  "dependencies": {
    "astro-icon": "^0.8.0"
  }
}
