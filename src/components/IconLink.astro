---
import { Icon } from 'astro-icon/components';

type Props = {
  iconName: string;
  href: string;
  text?: string;
};

const { iconName, href, text } = Astro.props;
---

<div class="not-prose">
    <a
      href={href}
      class={`${iconName} inline-flex items-center gap-3`}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Icon name={`mdi:${iconName}`} />
      <p>{text}</p>
    </a>
</div>
